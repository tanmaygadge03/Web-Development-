[8] Develop a responsive web page using Bootstrap Grid and Components for College
homepage with responsive sections

<!DOCTYPE html>
<html>
<head>
    <title>College Homepage</title>

    <!-- Bootstrap CSS -->

    <link rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>

        body
        {
            background-color: #f2f2f2;
        }

        .header
        {
            background-color: darkblue;
            color: white;
            padding: 30px;
            text-align: center;
        }

        .section
        {
            background-color: white;
            padding: 20px;
            margin-top: 20px;
            border-radius: 10px;
        }

        .footer
        {
            background-color: black;
            color: white;
            text-align: center;
            padding: 15px;
            margin-top: 20px;
        }

    </style>

</head>

<body>

    <!-- Header -->

    <div class="header">

        <h1>I2IT College</h1>

        <p>Welcome to College Homepage</p>

    </div>

    <!-- Bootstrap Container -->

    <div class="container">

        <!-- Responsive Row -->

        <div class="row">

            <!-- About Section -->

            <div class="col-md-4">

                <div class="section">

                    <h3>About College</h3>

                    <p>
                        I2IT College provides quality education in Engineering,
                        Computer Science, and Management.
                    </p>

                </div>

            </div>

            <!-- Courses Section -->

            <div class="col-md-4">

                <div class="section">

                    <h3>Courses</h3>

                    <ul>
                        <li>BCA</li>
                        <li>B.Tech</li>
                        <li>MCA</li>
                    </ul>

                </div>

            </div>

            <!-- Contact Section -->

            <div class="col-md-4">

                <div class="section">

                    <h3>Contact</h3>

                    <p>Email: info@i2it.com</p>

                    <p>Phone: +91 9876543210</p>

                </div>

            </div>

        </div>

        <!-- Another Responsive Row -->

        <div class="row">

            <div class="col-md-6">

                <div class="section">

                    <h3>Events</h3>

                    <p>
                        TechFest, Coding Competition, Workshops and Seminars.
                    </p>

                </div>

            </div>

            <div class="col-md-6">

                <div class="section">

                    <h3>Placement</h3>

                    <p>
                        Top companies visit the campus every year for placements.
                    </p>

                </div>

            </div>

        </div>

    </div>

    <!-- Footer -->

    <div class="footer">

        <p>© 2026 I2IT College | All Rights Reserved</p>

    </div>

    <!-- Bootstrap JS -->

    <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js">
    </script>

</body>
</html>
