[7]  Design a web page to display a student result dashboard.
Use headings for title and section names
Create a table showing subjects, marks, grade
Apply:
Inline CSS for highlighting top scorer
Internal CSS for table styling
External CSS for overall page theme

<!DOCTYPE html>
<html>
<head>
    <title>Student Result Dashboard</title>

    <!-- External CSS -->
    <link rel="stylesheet" href="style.css">

    <!-- Internal CSS -->

    <style>

        table
        {
            width: 80%;
            margin: auto;
            border-collapse: collapse;
            background-color: white;
        }

        th
        {
            background-color: darkblue;
            color: white;
            padding: 10px;
        }

        td
        {
            text-align: center;
            padding: 10px;
        }

        table, th, td
        {
            border: 1px solid black;
        }

        h1, h2
        {
            text-align: center;
        }

    </style>

</head>

<body>

    <!-- Heading -->

    <h1><u>Student Result Dashboard</u></h1>

    <h2>Semester Result</h2>

    <!-- Result Table -->

    <table>

        <tr>
            <th>Subject</th>
            <th>Marks</th>
            <th>Grade</th>
        </tr>

        <!-- Inline CSS for Top Scorer -->

        <tr style="background-color: yellow; font-weight: bold;">

            <td>Web Development</td>

            <td>95</td>

            <td>A+</td>

        </tr>

        <tr>
            <td>Python</td>
            <td>88</td>
            <td>A</td>
        </tr>

        <tr>
            <td>Database</td>
            <td>82</td>
            <td>B+</td>
        </tr>

        <tr>
            <td>Java</td>
            <td>90</td>
            <td>A+</td>
        </tr>

    </table>

</body>
</html>

/* External CSS */

body
{
    font-family: Arial;
    background-color: #f2f2f2;
    margin: 20px;
}
