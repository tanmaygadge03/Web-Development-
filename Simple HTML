[1] Create a simple HTML page to display Student portfolio page showing name, course,
hobbies Using text formatting tags (ex. text fields, checkboxes, and radio buttons)

<!DOCTYPE html>
<html>
<head>
    <title>Student Portfolio</title>
</head>
<body>

    <h1 align="center"><u>Student Portfolio</u></h1>

    <form>
        <!-- Name -->
        <p>
            <b>Name:</b><br>
            <input type="text" name="name" placeholder="Enter your name">
        </p>

        <!-- Course -->
        <p>
            <b>Course:</b><br>
            <input type="text" name="course" placeholder="Enter your course">
        </p>

        <!-- Gender (Radio Buttons) -->
        <p>
            <b>Gender:</b><br>
            <input type="radio" name="gender" value="Male"> Male<br>
            <input type="radio" name="gender" value="Female"> Female<br>
            <input type="radio" name="gender" value="Other"> Other
        </p>

        <!-- Hobbies (Checkboxes) -->
        <p>
            <b>Hobbies:</b><br>
            <input type="checkbox" name="hobbies" value="Reading"> Reading<br>
            <input type="checkbox" name="hobbies" value="Sports"> Sports<br>
            <input type="checkbox" name="hobbies" value="Music"> Music<br>
            <input type="checkbox" name="hobbies" value="Traveling"> Traveling
        </p>

        <!-- About Section -->
        <p>
            <b>About Me:</b><br>
            <textarea rows="4" cols="40" placeholder="Write about yourself..."></textarea>
        </p>

        <!-- Submit Button -->
        <p>
            <input type="submit" value="Submit">
            <input type="reset" value="Reset">
        </p>
    </form>

</body>
</html>
