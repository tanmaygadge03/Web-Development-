[15] Create a PHP script to Store subject marks in an array and display maximum marks and
student percentage.

<!DOCTYPE html>
<html>
<head>
    <title>Student Marks Program</title>

    <style>

        body
        {
            font-family: Arial;
            background-color: #f2f2f2;
        }

        .container
        {
            width: 500px;
            margin: auto;
            background-color: white;
            padding: 20px;
            border-radius: 10px;
            margin-top: 50px;
        }

        h1
        {
            text-align: center;
            color: darkblue;
        }

        h2
        {
            color: darkred;
        }

    </style>

</head>

<body>

    <div class="container">

        <h1><u>Student Marks Array Program</u></h1>

        <?php

            // Store Marks in Array

            $marks = array(85, 90, 78, 88, 95);

            // Display Marks

            echo "<h2>Subject Marks</h2>";

            foreach($marks as $m)
            {
                echo $m . "<br>";
            }

            // Maximum Marks

            $max = max($marks);

            // Total Marks

            $total = array_sum($marks);

            // Percentage

            $percentage = $total / count($marks);

            // Display Result

            echo "<br><b>Maximum Marks:</b> " . $max;

            echo "<br><br><b>Percentage:</b> " . $percentage . "%";

        ?>

    </div>

</body>
</html>
